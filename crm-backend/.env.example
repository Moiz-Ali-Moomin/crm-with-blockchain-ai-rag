# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────
# Database (FIXED)
# ─────────────────────────────────────────
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=strongpassword123
POSTGRES_DB=crm_db

DATABASE_URL=postgresql://crm_user:strongpassword123@postgres:5432/crm_db?schema=public

# ─────────────────────────────────────────
# Redis (FIXED)
# ─────────────────────────────────────────
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@redis:6379

# ─────────────────────────────────────────
# MongoDB (FIXED)
# ─────────────────────────────────────────
MONGO_USER=crm_mongo
MONGO_PASSWORD=strongmongo123
MONGO_URI=mongodb://crm_mongo:strongmongo123@mongodb:27017/crm_logs

# ─────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────
JWT_SECRET=super-secure-prod-jwt-key-CHANGE
JWT_REFRESH_SECRET=super-secure-refresh-key-CHANGE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────
# Email
# ─────────────────────────────────────────
SENDGRID_API_KEY=your-real-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=CRM Platform

# ─────────────────────────────────────────
# Twilio
# ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-real
TWILIO_AUTH_TOKEN=your-real
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=live_key
STRIPE_PUBLISHABLE_KEY=live_key
STRIPE_WEBHOOK_SECRET=live_secret

# ─────────────────────────────────────────
# PayPal
# ─────────────────────────────────────────
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=your-real
PAYPAL_CLIENT_SECRET=your-real

# ─────────────────────────────────────────
# Razorpay
# ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_PLAN_STARTER=plan_xxxxxxxx
RAZORPAY_PLAN_PRO=plan_xxxxxxxx
RAZORPAY_PLAN_PRO_PLUS=plan_xxxxxxxx
RAZORPAY_PLAN_ULTIMATE=plan_xxxxxxxx
RAZORPAY_PLAN_ENTERPRISE=plan_xxxxxxxx

# ─────────────────────────────────────────
# AI
# ─────────────────────────────────────────
# LLM — Anthropic Claude (required for all AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Embeddings — Ollama must be running locally with nomic-embed-text pulled:
#   ollama serve
#   ollama pull nomic-embed-text
# Optional overrides (defaults shown):
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=nomic-embed-text
# LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.2

# ─────────────────────────────────────────
# Blockchain — Polygon Amoy testnet
# ─────────────────────────────────────────
# Get a free RPC from https://alchemy.com or https://infura.io
RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Optional — enables push-based event subscriptions (faster payment detection)
WS_RPC_URL=wss://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# USDC on Polygon Amoy testnet (faucet: https://faucet.circle.com)
USDC_CONTRACT_ADDRESS=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582

# Custodial wallet private key — 0x-prefixed 32-byte hex
# Generate: node -e "const {ethers}=require('ethers');console.log(ethers.Wallet.createRandom().privateKey)"
PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY

# Legacy keys (used by BlockchainModule — separate from EthereumPaymentModule above)
BLOCKCHAIN_NETWORK=polygon-amoy
BLOCKCHAIN_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BLOCKCHAIN_PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY
BLOCKCHAIN_CONTRACT_ADDR=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582

# ─────────────────────────────────────────
# Logging
# ─────────────────────────────────────────
LOG_LEVEL=info

# ─────────────────────────────────────────
# OpenTelemetry
# ─────────────────────────────────────────
# Base URL of the OTEL Collector (no path — SDK appends /v1/traces automatically).
# Local dev: leave unset to get console output.
# Docker / production: use the collector's container name.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://crm_otel_collector:4318

# Set to "true" to disable tracing entirely (e.g. in unit-test environments).
# OTEL_SDK_DISABLED=false

# Overrides the service name shown in Grafana Tempo. Default: crm-backend.
# OTEL_SERVICE_NAME=crm-api

# Injected automatically by CD pipeline as the Docker image tag (e.g. sha-abc1234).
# Set manually for local testing if you care about service.version in traces.
# APP_VERSION=local